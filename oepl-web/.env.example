# ── Supabase (production) ──
# Create a project at https://supabase.com
# Run supabase/*.sql files in SQL Editor (news.sql first, then child tables, then storage.sql)
# Create an admin user in Authentication → Users (disable public sign-up)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Local dev only (when Supabase vars are empty) ──
# Do NOT set these in production — they are bundled into the client.
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=oepl-admin
